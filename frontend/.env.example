# Next.js rewrites用のバックエンドURL（/api/v1/:path* 及び /images/:path* の転送先）
# ローカル開発 (pnpm dev): http://localhost:8080
# Codespaces: https://<workspace>-8080.app.github.dev
# Docker/ECS: バックエンドのコンテナ名またはサービスURLに変更してビルドする
#   例: http://<バックエンドコンテナ名>:8080
#   ※ コンテナ名はプロジェクトのディレクトリ名に依存するため環境ごとに異なる
BACKEND_URL=http://localhost:8080

# ログイン後のリダイレクト先パス暗号化用シークレットキー（本番環境では必ず強力なランダム文字列に変更してください）
# 以下のコマンドで生成してfrontend/.envに追加:
# echo "REDIRECT_SECRET=$(openssl rand -hex 32)" >> frontend/.env
# REDIRECT_SECRET=
