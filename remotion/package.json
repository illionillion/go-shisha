{
  "name": "remotion",
  "version": "0.1.0",
  "private": true,
  "description": "シーシャ行こう プロモGIF生成（Remotion）",
  "scripts": {
    "studio": "pnpm exec remotion studio src/index.ts",
    "render": "pnpm exec remotion render src/index.ts ShishaPromo ../docs/demo.gif --codec=gif",
