# フロントエンド本番ビルド用 .dockerignore（ビルドコンテキスト: リポジトリルート）

# バックエンドはフロントエンドビルドに不要
backend/

# ルートのビルド不要ファイル
node_modules
docs/
scripts/
.github/
lefthook.yml
tsconfig.json
*.md

# フロントエンドのビルド成果物・キャッシュ
frontend/node_modules
frontend/.next
frontend/__image_snapshots__
frontend/storybook-static
frontend/coverage
frontend/tsconfig.tsbuildinfo

# フロントエンドのテスト・開発ツール設定
frontend/test
frontend/vitest.config.ts
frontend/eslint.config.ts
frontend/orval.config.ts
frontend/compose.vrt.yml
frontend/Dockerfile.vrt
frontend/*.md

# 機密情報の除外
# ルート直下の .env 系（DB接続情報・JWT_SECRET 等）
/.env
/.env.*
# frontend の .env.local 系（REDIRECT_SECRET 等）はビルドコンテキストから除外
# .env.development / .env.production はコミット対象のため除外しない
frontend/.env.local
frontend/.env.*.local

# Git・ログ
.git
*.log
